# ============================================
# OSA ERP — Production Environment Variables
# ============================================
# Set these in Vercel → Settings → Environment Variables
# NEVER commit real secrets to Git!

# ---- Database (Supabase PostgreSQL) ----
# IMPORTANT: Before deploying, change prisma/schema.prisma provider to "postgresql"
# Then set these URLs:
#
# Connection pooler (for serverless):
# DATABASE_URL="postgresql://postgres.fcbaoaucywuqmjcsnfyb:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Direct connection (for migrations):
# DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.fcbaoaucywuqmjcsnfyb.supabase.co:5432/postgres"
#
# Replace [YOUR-PASSWORD] with: @M7mad1995105

DATABASE_URL="postgresql://postgres.fcbaoaucywuqmjcsnfyb:%40M7mad1995105@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ---- Auth Secrets ----
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="osa-erp-production-secret-CHANGE-ME-32-chars"

# Demo account email (used by /api/auth/demo-login)
DEMO_EMAIL="demo@osaerp.com"

# ---- Public App URL ----
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL="https://fcbaoaucywuqmjcsnfyb.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_UGLiQhJLPlFUy33R9LPA4A_ZfCy9-rk"

# ---- SMTP (optional) ----
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASSWORD=""

NODE_ENV="production"
