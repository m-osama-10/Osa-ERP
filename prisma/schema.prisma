// Osa ERP - Prisma Schema
// Comprehensive ERP data model
// Supports both SQLite (dev) and PostgreSQL (production / Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Currency ====================
model Currency {
  id        String   @id @default(cuid())
  code      String   @unique // EGP, USD, SAR, EUR
  name      String   // جنيه مصري, دولار أمريكي
  nameEn    String?
  symbol    String   // ج.م, $, ر.س, €
  isBase    Boolean  @default(false) // العملة الأساسية
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ExchangeRate {
  id         String   @id @default(cuid())
  fromCode   String   // EGP, USD
  toCode     String   // USD, EGP
  rate       Float    // multiplier
  date       DateTime @default(now())
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([fromCode, toCode, date])
}

// ==================== Core / Organization ====================
model Company {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  taxNo     String?
  phone     String?
  email     String?
  address   String?
  currency  String   @default("EGP")
  logo      String?
  createdAt DateTime @default(now())
  branches  Branch[]
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==================== Accounting ====================
model Account {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameEn    String?
  type      String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subtype   String?
  parentId  String?
  parent    Account? @relation("AccountTree", fields: [parentId], references: [id])
  children  Account[] @relation("AccountTree")
  isActive  Boolean  @default(true)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  journalLines JournalLine[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNo     String   @unique
  date        DateTime
  description String
  reference   String?
  branchId    String?
  totalDebit  Float    @default(0)
  totalCredit Float    @default(0)
  status      String   @default("POSTED") // DRAFT, POSTED
  createdAt   DateTime @default(now())
  lines       JournalLine[]
}

model JournalLine {
  id          String   @id @default(cuid())
  entryId     String
  entry       JournalEntry @relation(fields: [entryId], references: [id])
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  debit       Float    @default(0)
  credit      Float    @default(0)
  description String?
  costCenterId String?
}

model CostCenter {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  parentId  String?
  parent    CostCenter? @relation("CostCenterTree", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostCenterTree")
  isActive  Boolean  @default(true)
}

// ==================== Customers & Suppliers ====================
model Customer {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameEn      String?
  type        String   @default("INDIVIDUAL") // INDIVIDUAL, COMPANY
  phone       String?
  email       String?
  address     String?
  taxNo       String?
  creditLimit Float    @default(0)
  balance     Float    @default(0)
  openingBalance Float @default(0)
  currency    String   @default("SAR")
  isActive    Boolean  @default(true)
  branchId    String?
  createdAt   DateTime @default(now())
  invoices    Invoice[]
}

model Supplier {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameEn      String?
  phone       String?
  email       String?
  address     String?
  taxNo       String?
  creditLimit Float    @default(0)
  balance     Float    @default(0)
  openingBalance Float @default(0)
  currency    String   @default("SAR")
  isActive    Boolean  @default(true)
  branchId    String?
  createdAt   DateTime @default(now())
  purchases   Purchase[]
}

// ==================== Invoices / Sales / Purchases ====================
model Invoice {
  id            String   @id @default(cuid())
  invoiceNo     String   @unique
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  date          DateTime
  dueDate       DateTime?
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  discountType  String   @default("FIXED") // FIXED (amount) or PERCENT
  taxRate       Float    @default(14)
  taxAmount     Float    @default(0)
  total         Float    @default(0)
  paidAmount    Float    @default(0)
  status        String   @default("UNPAID") // PAID, UNPAID, PARTIAL, OVERDUE
  type          String   @default("SALES") // SALES, POS, QUOTE, RETURN
  notes         String?
  branchId      String?
  createdBy     String?
  createdAt     DateTime @default(now())
  items         InvoiceItem[]
}

model InvoiceItem {
  id            String  @id @default(cuid())
  invoiceId     String
  invoice       Invoice @relation(fields: [invoiceId], references: [id])
  itemId        String
  item          Item    @relation(fields: [itemId], references: [id])
  quantity      Float
  price         Float
  discount      Float   @default(0)
  discountType  String  @default("FIXED") // FIXED or PERCENT
  total         Float
}

model Purchase {
  id          String   @id @default(cuid())
  purchaseNo  String   @unique
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  date        DateTime
  subtotal    Float    @default(0)
  discount    Float    @default(0)
  taxAmount   Float    @default(0)
  total       Float    @default(0)
  paidAmount  Float    @default(0)
  status      String   @default("UNPAID")
  notes       String?
  branchId    String?
  createdAt   DateTime @default(now())
  items       PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id])
  quantity   Float
  price      Float
  total      Float
}

// ==================== Inventory ====================
model Item {
  id            String   @id @default(cuid())
  sku           String   @unique
  barcode       String?
  name          String
  nameEn        String?
  description   String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  unit          String   @default("PCS")
  costPrice     Float    @default(0)
  salePrice     Float    @default(0)
  qtyOnHand     Float    @default(0)
  reorderLevel  Float    @default(10)
  isActive      Boolean  @default(true)
  isManufactured Boolean @default(false)
  createdAt     DateTime @default(now())
  invoiceItems  InvoiceItem[]
  purchaseItems PurchaseItem[]
  bomId         String?
  boms          BOMLine[] @relation("BOMItem")
  bomComponents BOMLine[] @relation("BOMComponent")
}

model Category {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  parentId  String?
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  items     Item[]
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  branchId  String?
  address   String?
  isActive  Boolean  @default(true)
}

model StockMovement {
  id          String   @id @default(cuid())
  itemId      String
  type        String   // IN, OUT, TRANSFER, ADJUST
  quantity    Float
  fromWarehouseId String?
  toWarehouseId String?
  reference   String?
  date        DateTime @default(now())
}

// ==================== Production / BOM ====================
model BOM {
  id          String         @id @default(cuid())
  productCode String
  productName String
  version     String         @default("1.0")
  totalCost   Float          @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  lines       BOMLine[]
  orders      ProductionOrder[]
}

model BOMLine {
  id          String @id @default(cuid())
  bomId       String
  bom         BOM    @relation(fields: [bomId], references: [id])
  itemId      String
  item        Item   @relation("BOMComponent", fields: [itemId], references: [id])
  quantity    Float
  productId   String?
  productItem Item?  @relation("BOMItem", fields: [productId], references: [id])
}

model ProductionOrder {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  bomId       String?
  bom         BOM?     @relation(fields: [bomId], references: [id])
  productName String
  quantity    Float
  unitCost    Float    @default(0)
  totalCost   Float    @default(0)
  status      String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  startDate   DateTime @default(now())
  endDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
}

// ==================== Representatives ====================
model Representative {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  phone       String?
  email       String?
  route       String?
  branchId    String?
  status      String   @default("OFFLINE") // ONLINE, OFFLINE
  lastSync    DateTime?
  totalVisits Int      @default(0)
  totalCollected Float @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  visits      RepVisit[]
}

model RepVisit {
  id          String   @id @default(cuid())
  repId       String
  rep         Representative @relation(fields: [repId], references: [id])
  customerId  String?
  customerName String?
  visitDate   DateTime @default(now())
  status      String   @default("VISITED") // VISITED, COMPLETED, CANCELLED
  collectedAmount Float @default(0)
  notes       String?
  gpsLat      Float?
  gpsLng      Float?
}

// ==================== Treasury / Banks ====================
model Cash {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  branchId  String?
  balance   Float    @default(0)
  currency  String   @default("EGP")
  isActive  Boolean  @default(true)
}

model BankAccount {
  id        String   @id @default(cuid())
  code      String   @unique
  bankName  String
  accountNo String
  iban      String?
  branchId  String?
  balance   Float    @default(0)
  currency  String   @default("EGP")
  isActive  Boolean  @default(true)
}

model Transaction {
  id        String   @id @default(cuid())
  type      String   // RECEIPT, PAYMENT, TRANSFER
  cashId    String?
  bankId    String?
  toCashId  String?
  toBankId  String?
  amount    Float
  date      DateTime @default(now())
  description String?
  refType   String?  // INVOICE, PURCHASE, MANUAL
  refId     String?
}

// ==================== HR ====================
model Employee {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameEn      String?
  nationalId  String?
  phone       String?
  email       String?
  position    String?
  department  String?
  branchId    String?
  hireDate    DateTime
  basicSalary    Float    @default(0)
  allowances     Float    @default(0)
  incentives     Float    @default(0)
  deductions     Float    @default(0)
  bankAccount    String?
  photo          String?
  files          String    @default("[]") // JSON array of file URLs
  archived       Boolean   @default(false)
  status         String    @default("ACTIVE") // ACTIVE, ON_LEAVE, RESIGNED, ARCHIVED
  createdAt      DateTime  @default(now())
  attendances    Attendance[]
  payroll        Payroll[]
  leaves         Leave[]
  advances       Advance[]
  deputations    Deputation[]
  history        EmployeeHistory[]
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  workHours   Float    @default(0)
  overtime    Float    @default(0)
  lateMinutes Int      @default(0)
  status      String   @default("PRESENT") // PRESENT, ABSENT, LATE, LEAVE, WEEKEND, HOLIDAY
  notes       String?
}

model Payroll {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id])
  month         Int
  year          Int
  basicSalary   Float
  allowances    Float
  incentives    Float
  deductions    Float
  advancesPaid  Float     @default(0)
  overtimePay   Float     @default(0)
  netSalary     Float
  status        String    @default("PENDING") // PENDING, PAID
  paidAt        DateTime?
  createdAt     DateTime  @default(now())

  @@unique([employeeId, month, year])
}

model Leave {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  days        Float    @default(1)
  type        String   // ANNUAL, SICK, CASUAL, UNPAID
  reason      String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedAt DateTime @default(now())
  approvedBy  String?
  approvedAt  DateTime?
}

model Advance {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  amount      Float
  type        String   @default("ADVANCE") // ADVANCE, LOAN
  installments Int     @default(1)
  paidInstallments Int @default(0)
  date        DateTime @default(now())
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  notes       String?
}

model Deputation {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  destination String
  purpose     String
  startDate   DateTime
  endDate     DateTime
  allowance   Float    @default(0)
  status      String   @default("PENDING") // PENDING, APPROVED, COMPLETED
  notes       String?
}

model EmployeeHistory {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  type        String   // HIRE, PROMOTION, PENALTY, REWARD, SALARY_CHANGE, RESIGN
  title       String
  description String?
  date        DateTime @default(now())
  amount      Float?
}

// ==================== Users / Auth ====================
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String
  role        String   @default("USER") // ADMIN, ACCOUNTANT, SALES, HR, USER
  branchId    String?
  permissions String   @default("[]") // JSON array of permission keys
  twoFA       Boolean  @default(false)
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  auditLogs   AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ==================== Notifications ====================
model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null = broadcast to all
  type      String   // INFO, WARNING, ERROR, SUCCESS
  title     String
  message   String
  module    String?  // accounting, inventory, sales...
  refType   String?  // INVOICE, ITEM, CHEQUE...
  refId     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==================== Settings (key-value) ====================
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON string
}
